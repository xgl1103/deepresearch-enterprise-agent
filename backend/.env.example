# Copy this file to .env. Never commit real credentials.
APP_TOKEN=
# Alternative: APP_TOKEN_FILE=/run/secrets/app_token
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MCP_APP_ID=
# Alternative: MCP_APP_ID_FILE=/run/secrets/mcp_app_id

REDIS_URL=redis://:replace-with-redis-password@127.0.0.1:6379/0
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/deepresearch

# Optional one-time bootstrap account. Password must be at least 12 characters.
BOOTSTRAP_USERNAME=
BOOTSTRAP_PASSWORD=
SESSION_COOKIE_SECURE=false
SESSION_IDLE_TTL_SECONDS=3600
SESSION_ABSOLUTE_TTL_SECONDS=86400
APP_ENV=development
METRICS_TOKEN=
# Alternative: METRICS_TOKEN_FILE=/run/secrets/metrics_token

# Admission and cost controls
USER_RESEARCH_PER_MINUTE=5
USER_RESEARCH_PER_DAY=100
USER_CONCURRENT_RESEARCH=2
MAX_INITIAL_SEARCH_QUERIES=5
MAX_RESEARCH_LOOPS_ALLOWED=5
# Provider prices per one million tokens, in your chosen accounting currency.
MODEL_PRICING_JSON={}

# Production: false, and run `python -m agent.worker` separately.
# Local one-process development: true.
EMBEDDED_TASK_WORKER=false
TASK_MAX_ATTEMPTS=3
TASK_CLAIM_IDLE_MS=60000
TASK_STATUS_TTL_SECONDS=604800
EVENT_STREAM_MAXLEN=10000
